font-family = "CodeNewRoman Nerd Font"
font-size = 14
freetype-load-flags = "hinting"
font-thicken = true
mouse-hide-while-typing = true

theme = light:solarized_light,dark:alacritty

adjust-cell-height=3

cursor-style = block
cursor-style-blink = false

cursor-invert-fg-bg = true
shell-integration-features = no-cursor
shell-integration = fish

window-width = 120
window-height = 45
window-padding-x = 0
window-padding-y = 0

confirm-close-surface = false
clipboard-paste-protection = false
unfocused-split-opacity = 1.0

# Tmux keybindings
keybind = cmd+digit_1=text:\x02\x31
keybind = cmd+digit_2=text:\x02\x32
keybind = cmd+digit_3=text:\x02\x33
keybind = cmd+digit_4=text:\x02\x34
keybind = cmd+digit_5=text:\x02\x35
keybind = cmd+digit_6=text:\x02\x36
keybind = cmd+digit_7=text:\x02\x37
keybind = cmd+digit_8=text:\x02\x38
keybind = cmd+digit_9=text:\x02\x39
keybind = cmd+digit_0=text:\x02\x30

keybind = cmd+shift+d=text:\x02-
keybind = cmd+d=text:\x02\\

keybind = cmd+enter=text:\x02z

# Better movements
keybind = cmd+l=text:\x02l
keybind = cmd+j=text:\x02j
keybind = cmd+k=text:\x02k
keybind = cmd+h=text:\x02h

# Resize panes
keybind = cmd+shift+h=text:\x02\x08
keybind = cmd+shift+j=text:\x02\x0a
keybind = cmd+shift+k=text:\x02\x0b
keybind = cmd+shift+l=text:\x02\x0c

# Create new pane
keybind = cmd+t=text:\x02c
keybind = cmd+semicolon=text:\x02;

# Additional bindings
keybind = cmd+p=text:\x02P
keybind = cmd+g=text:\x02g
